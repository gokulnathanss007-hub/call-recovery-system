# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Used by the dashboard's auth/RLS-bound client (browser + server). Safe to expose —
# RLS policies (see supabase/migrations/002_*) restrict what the anon key can read.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Exotel ────────────────────────────────────────────────────────────────────
# Auth Token from: my.exotel.com → Settings → API Credentials
EXOTEL_WEBHOOK_SECRET=your-exotel-auth-token
# Must match the URL configured in the Passthru applet
EXOTEL_WEBHOOK_URL=https://medixumcge.vercel.app/api/webhooks/exotel

# ── Meta WhatsApp ──────────────────────────────────────────────────────────────
# From: Meta Developer Console → WhatsApp → API Setup
META_WHATSAPP_TOKEN=your-meta-api-token
META_PHONE_NUMBER_ID=your-phone-number-id
# From: Meta Developer Console → App → Settings → Basic → App Secret
META_APP_SECRET=your-meta-app-secret
# You choose this — must match what you enter in Meta webhook config
META_WEBHOOK_VERIFY_TOKEN=cge_verify_2026

# ── Anthropic (direct — preferred once available) ───────────────────────────────
# From: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── AICredits (temporary stopgap — OpenAI-compatible gateway, billed in INR) ───
# https://aicredits.in/dashboard — only needed if ANTHROPIC_API_KEY isn't set up yet
AICREDITS_API_KEY=your-aicredits-api-key

# ── Trigger.dev ───────────────────────────────────────────────────────────────
# From: cloud.trigger.dev → Project → Settings
TRIGGER_SECRET_KEY=your-trigger-secret-key
TRIGGER_PROJECT_ID=proj_your-project-id
